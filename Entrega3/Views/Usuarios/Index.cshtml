@model IEnumerable<Entrega3.Models.Usuario>
@{
    ViewBag.Title = "Admin Usuarios";
}

<div class="row mb-4 mt-4">
    <div class="col-12">
        <h2 class="fw-bold border-bottom border-light border-opacity-25 pb-2 text-white">Panel de Administración</h2>
        <p class="text-white-50">Gestiona y supervisa a los usuarios del sistema.</p>
    </div>
</div>

<div class="glass-card border-0 p-4">
    <div class="border-bottom border-light border-opacity-25 mb-4 pb-2 d-flex justify-content-between align-items-center">
        <h5 class="mb-0 text-white"><i class="bi bi-people"></i> Gestión de Usuarios del Sistema</h5>
        <a href="@Url.Action("Crear", "Usuarios")" class="btn btn-sm btn-light rounded-pill px-3"><i class="bi bi-person-plus"></i> Nuevo Usuario</a>
    </div>
    <div class="bg-transparent table-responsive">
        <table class="table table-borderless table-hover text-center align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Nombre</th>
                    <th>Correo</th>
                    <th>Rol</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    <tr>
                        <td>@u.Id</td>
                        <td>@u.NombreCompleto</td>
                        <td>@u.Correo</td>
                        <td>@u.NombreRol</td>
                        <td>
                            @if (u.Estado)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inactivo</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex justify-content-center gap-2">
                                <a href="@Url.Action("Editar", "Usuarios", new { id = u.Id })" class="btn btn-sm btn-light" title="Editar"><i class="bi bi-pencil"></i></a>
                                @using (Html.BeginForm("ToggleStatus", "Usuarios", new { id = u.Id }, FormMethod.Post, new { onsubmit = "return confirm('¿Está seguro de cambiar el estado de este usuario?');" }))
                                {
                                    @Html.AntiForgeryToken()
                                    if (u.Estado)
                                    {
                                        <button type="submit" class="btn btn-sm btn-danger" title="Desactivar"><i class="bi bi-power"></i></button>
                                    }
                                    else
                                    {
                                        <button type="submit" class="btn btn-sm btn-success" title="Activar"><i class="bi bi-power"></i></button>
                                    }
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
