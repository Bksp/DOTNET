<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - TechHelpWeb</title>
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")

    <style>
        body { 
            font-family: 'Poppins', sans-serif; 
            background-color: #0f1115; /* Fondo oscuro sólido de base */
            background-image: 
                radial-gradient(at 0% 0%, rgba(25, 30, 45, 1) 0%, transparent 50%), 
                radial-gradient(at 100% 100%, rgba(20, 25, 40, 1) 0%, transparent 50%),
                radial-gradient(at 50% 50%, rgba(15, 20, 30, 1) 0%, transparent 50%);
            min-height: 100vh;
            color: #fff;
            overflow-x: hidden;
        }
        .sidebar { 
            height: 100vh; 
            width: 260px; 
            position: fixed; 
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border-right: 1px solid rgba(255, 255, 255, 0.1);
            z-index: 1000;
        }
        .sidebar a { 
            color: rgba(255,255,255,0.7); 
            text-decoration: none; 
            padding: 15px 25px; 
            display: block; 
            border-left: 4px solid transparent; 
            transition: all 0.3s ease; 
            font-weight: 500;
        }
        .sidebar a:hover, .sidebar a.active { 
            background: rgba(255,255,255,0.1); 
            color: white; 
            border-left-color: #fff; 
        }
        .main-content { 
            margin-left: 260px; 
            padding: 30px; 
            width: calc(100% - 260px); 
            min-height: 100vh;
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 16px;
            color: white;
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
        }
        .glass-nav {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 16px;
            margin-bottom: 30px;
        }
        /* Custom scrollbar */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: rgba(255, 255, 255, 0.05); }
        ::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.2); border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: rgba(255, 255, 255, 0.3); }
        
        /* Table overrides for dark glass theme */
        .table { --bs-table-color: #fff; --bs-table-bg: transparent; --bs-table-hover-color: #fff; margin-bottom: 0; color: #fff; }
        .table-hover tbody tr:hover { background-color: rgba(255,255,255,0.08); color: #fff; }
        .table-light { --bs-table-bg: rgba(255,255,255,0.1); --bs-table-color: #fff; }
        .table-light th { background-color: transparent; color: #fff; border-bottom: 1px solid rgba(255,255,255,0.2); font-weight: 600; }
        .table td, .table th { border-color: rgba(255,255,255,0.1); color: #fff !important; }
        
        /* Form inputs override */
        .form-control, .form-select {
            background-color: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            color: white;
            color-scheme: dark;
            accent-color: #ffffff;
        }
        .form-select {
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%23ffffff' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='m2 5 6 6 6-6'/%3e%3c/svg%3e");
        }
        .form-control:focus, .form-select:focus {
            background-color: rgba(255, 255, 255, 0.15);
            border-color: rgba(255, 255, 255, 0.5);
            color: white;
            box-shadow: 0 0 0 0.25rem rgba(255, 255, 255, 0.1);
        }
        .form-control::placeholder { color: rgba(255, 255, 255, 0.5); }
        .form-select option { background-color: #1a1e29; color: #fff; }
        
        /* Buttons glass override */
        .btn-primary { background: rgba(13, 110, 253, 0.6); border: 1px solid rgba(13, 110, 253, 0.8); }
        .btn-primary:hover { background: rgba(13, 110, 253, 0.8); border-color: #0d6efd; }
    </style>
</head>
<body>
    <div class="d-flex">
        <!-- Sidebar -->
        <div class="sidebar d-flex flex-column">
            <h4 class="text-center py-4 fw-bold m-0 border-bottom border-light border-opacity-25 text-white">
                <i class="bi bi-pc-display text-info"></i> TechHelp
            </h4>
            <div class="pt-3 flex-grow-1">
                @if (Session["UsuarioId"] != null)
                {
                    int rolId = (int)Session["RolId"];
                    if (rolId == 1) // Admin
                    {
                        <a href="@Url.Action("Index", "Usuarios")" class="@(ViewContext.RouteData.Values["controller"].ToString() == "Usuarios" ? "active" : "")">
                            <i class="bi bi-people me-2 fs-5"></i> Usuarios
                        </a>
                    }
                    else if (rolId == 2) // Soporte
                    {
                        <a href="@Url.Action("DashboardSoporte", "Solicitudes")" class="@(ViewContext.RouteData.Values["action"].ToString() == "DashboardSoporte" ? "active" : "")">
                            <i class="bi bi-speedometer2 me-2 fs-5"></i> Dashboard
                        </a>
                    }
                    else if (rolId == 3) // Usuario Normal
                    {
                        <a href="@Url.Action("MisSolicitudes", "Solicitudes")" class="@(ViewContext.RouteData.Values["action"].ToString() == "MisSolicitudes" ? "active" : "")">
                            <i class="bi bi-ticket-detailed me-2 fs-5"></i> Mis Solicitudes
                        </a>
                    }

                    <a href="@Url.Action("Index", "Perfil")" class="@(ViewContext.RouteData.Values["controller"].ToString() == "Perfil" ? "active" : "")">
                        <i class="bi bi-person me-2 fs-5"></i> Mi Perfil
                    </a>
                }
                else
                {
                    <a href="@Url.Action("Login", "Auth")" class="@(ViewContext.RouteData.Values["action"].ToString() == "Login" ? "active" : "")">
                        <i class="bi bi-box-arrow-in-right me-2 fs-5"></i> Iniciar Sesión
                    </a>
                }
            </div>
            @if (Session["UsuarioId"] != null)
            {
                <div class="mt-auto mb-4 border-top border-light border-opacity-25 pt-3">
                    <a href="@Url.Action("Logout", "Auth")" class="text-danger">
                        <i class="bi bi-box-arrow-right me-2 fs-5"></i> Salir
                    </a>
                </div>
            }
        </div>

        <!-- Main Content -->
        <div class="main-content flex-grow-1">
            @if (Session["UsuarioId"] != null)
            {
                <div class="glass-nav p-3 px-4 d-flex justify-content-between align-items-center">
                    <h5 class="m-0 fw-semibold">@ViewBag.Title</h5>
                    <div class="d-flex align-items-center">
                        <span class="me-3 fw-medium">Hola, @Session["NombreCompleto"]</span>
                        <div class="bg-white bg-opacity-25 rounded-circle d-flex align-items-center justify-content-center border border-light border-opacity-25" style="width: 42px; height: 42px;">
                            <i class="bi bi-person-fill fs-5 text-white"></i>
                        </div>
                    </div>
                </div>
            }

            <div id="alertContainer">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success bg-success bg-opacity-25 text-white border-0 alert-dismissible fade show shadow-sm glass-card mb-4" role="alert">
                        <strong><i class="bi bi-check-circle"></i> ¡Éxito!</strong> @TempData["SuccessMessage"]
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger bg-danger bg-opacity-25 text-white border-0 alert-dismissible fade show shadow-sm glass-card mb-4" role="alert">
                        <strong><i class="bi bi-exclamation-triangle"></i> ¡Error!</strong> @TempData["ErrorMessage"]
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
            </div>

            <div class="w-100">
                @RenderBody()
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")

    <script>
        function mostrarAlerta(mensaje, tipo) {
            const container = document.getElementById('alertContainer');
            let icon = '<i class="bi bi-info-circle"></i>';
            if (tipo === 'success') icon = '<i class="bi bi-check-circle"></i>';
            if (tipo === 'danger') icon = '<i class="bi bi-exclamation-triangle"></i>';
            
            container.innerHTML = `
                <div class="alert alert-${tipo} bg-${tipo} bg-opacity-25 text-white border-0 alert-dismissible fade show shadow-sm glass-card mb-4" role="alert">
                    <strong>${icon} ${tipo === 'success' ? '¡Éxito!' : (tipo === 'danger' ? '¡Error!' : 'Info')}</strong> ${mensaje}
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            `;
        }
    </script>
    
    @RenderSection("scripts", required: false)
</body>
</html>
